{
  "testId": "validator.claimSignature.valid.placedWithIngredient",
  "title": "Valid Claim Signature — c2pa.placed with Ingredient",
  "description": "Verifies that a conformant validator correctly reports a valid claim signature for an asset that was produced by placing a component ingredient. The ingredient is a real C2PA-signed JPEG; its manifest is embedded as a parentOf ingredient.",
  "specVersion": "2.2",
  "inputAsset": "../../testfiles/Dog.jpg",
  "manifest": {
    "alg": "Ed25519",
    "claim_generator_info": [
      {
        "name": "crTool/0.3.0",
        "version": "0.3.0"
      }
    ],
    "title": "tc-placed-with-ingredient",
    "assertions": [
      {
        "label": "c2pa.actions",
        "data": {
          "actions": [
            {
              "action": "c2pa.created",
              "digitalSourceType": "http://cv.iptc.org/newscodes/digitalsourcetype/trainedAlgorithmicMedia",
              "when": "2026-01-17T14:44:19.231Z"
            },
            {
              "action": "c2pa.placed",
              "when": "2026-01-17T15:44:19.231Z",
              "parameters": {
                "ingredientIds": ["test_ingredient"]
              }
            }
          ]
        }
      }
    ],
    "ingredients_from_files": [
      {
        "file_path": "../../testset/test_ingredient_manifest.jpg",
        "label": "test_ingredient",
        "relationship": "componentOf"
      }
    ]
  },
  "signingCert": "../../tests/fixtures/certs/ed25519.pub",
  "signingKey": "../../tests/fixtures/certs/ed25519.pem",
  "expectedResults": {
    "validationStatus": [
      {
        "code": "claimSignature.validated",
        "explanation": "The claim signature must be valid for an asset that places a component ingredient."
      }
    ]
  }
}
