{
  "testId": "validator.profile.violation.redacted.badReason",
  "title": "Profile Violation — c2pa.redacted with Non-URI Reason",
  "description": "Verifies that a conformant validator correctly reports a valid claim signature for a manifest where the c2pa.redacted action carries a reason value that is a plain string rather than the required absolute URI. A profile-aware validator MUST report this non-conformance.",
  "specVersion": "2.2",
  "inputAsset": "../../tests/fixtures/assets/Dog.jpg",
  "manifest": {
    "alg": "Ed25519",
    "claim_generator_info": [
      {
        "name": "crTool/0.3.0",
        "version": "0.3.0"
      }
    ],
    "title": "tc-n-redacted-bad-reason",
    "assertions": [
      {
        "label": "c2pa.actions",
        "data": {
          "actions": [
            {
              "action": "c2pa.created",
              "digitalSourceType": "http://cv.iptc.org/newscodes/digitalsourcetype/trainedAlgorithmicMedia",
              "when": "2026-01-17T14:44:19.231Z"
            },
            {
              "action": "c2pa.redacted",
              "when": "2026-01-17T15:44:19.231Z",
              "parameters": {
                "ingredientIds": ["COMPONENT"]
              },
              "reason": "I felt like it"
            }
          ]
        }
      }
    ],
    "ingredients": [
      {
        "title": "Test",
        "format": "image/jpeg",
        "relationship": "componentOf",
        "label": "COMPONENT"
      }
    ]
  },
  "signingCert": "../../tests/fixtures/certs/ed25519.pub",
  "signingKey": "../../tests/fixtures/certs/ed25519.pem",
  "expectedResults": {
    "validationStatus": [
      {
        "code": "claimSignature.validated",
        "explanation": "The claim signature is cryptographically valid. The non-URI reason field on c2pa.redacted is a profile-level violation."
      }
    ]
  }
}
